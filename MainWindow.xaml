<Window x:Class="FileUnlocker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FileUnlocker - 文件占用检测"
        Width="780"
        Height="540"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop"
        Icon="Assets/icon.ico"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="CornerRadius" Value="{StaticResource OverlayCornerRadius}" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="DangerButton"
               BasedOn="{StaticResource {x:Type Button}}"
               TargetType="Button">
            <Setter Property="Background" Value="#e81123" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{StaticResource ControlCornerRadius}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#ff4a5e" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#b00d1d" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="IconButton"
               BasedOn="{StaticResource {x:Type Button}}"
               TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource ControlCornerRadius}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FluentListViewItem"
               BasedOn="{StaticResource {x:Type ListViewItem}}"
               TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                                BorderThickness="0,0,0,1"
                                SnapsToDevicePixels="True">
                            <GridViewRowPresenter VerticalAlignment="Center"
                                                  Columns="{Binding Path=View.Columns, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                  Content="{TemplateBinding Content}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="0" RowDefinitions="Auto,Auto,*,Auto">

        <Border Grid.Row="0"
                Margin="16,12,16,0"
                Style="{StaticResource CardBorder}">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                <Grid.Resources>
                    <Style BasedOn="{StaticResource {x:Type Button}}" TargetType="Button">
                        <Setter Property="Padding" Value="12,6" />
                        <Setter Property="FontSize" Value="13" />
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                        <Setter Property="MinHeight" Value="32" />
                    </Style>
                </Grid.Resources>
                <TextBox x:Name="FilePathBox"
                         Grid.Column="0"
                         MinHeight="32"
                         Padding="8,6"
                         VerticalContentAlignment="Center"
                         FontSize="14" />
                <Button x:Name="BrowseFileBtn"
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        Click="BrowseFile_Click"
                        Content="选择文件" />
                <Button x:Name="BrowseFolderBtn"
                        Grid.Column="2"
                        Margin="8,0,0,0"
                        Click="BrowseFolder_Click"
                        Content="选择文件夹" />
                <Button x:Name="DetectBtn"
                        Grid.Column="3"
                        Margin="8,0,0,0"
                        Click="Detect_Click"
                        Content="检测"
                        FontWeight="SemiBold"
                        Style="{DynamicResource AccentButtonStyle}" />
                <Button x:Name="SettingsBtn"
                        Grid.Column="4"
                        Margin="8,0,0,0"
                        Click="SettingsBtn_Click"
                        Style="{StaticResource IconButton}"
                        ToolTip="设置">
                    <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}"
                               FontSize="16"
                               Text="&#xE713;" />
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="16,8,16,0"
                Padding="10,6"
                Style="{StaticResource CardBorder}">
            <StackPanel Height="28"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <TextBlock x:Name="ScanDepthLabel"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="文件夹扫描深度：" />
                <RadioButton x:Name="ScanCurrent"
                             Margin="0,0,12,0"
                             Content="仅当前目录"
                             GroupName="ScanDepth" />
                <RadioButton x:Name="ScanOneLevel"
                             Margin="0,0,12,0"
                             Content="含一层子目录"
                             GroupName="ScanDepth" />
                <RadioButton x:Name="ScanRecursive"
                             Margin="0,0,16,0"
                             Content="递归所有子目录"
                             GroupName="ScanDepth"
                             IsChecked="True" />
                <Separator Width="1"
                           Margin="0,2"
                           Background="{DynamicResource ControlStrokeColorSecondaryBrush}"
                           Style="{x:Null}" />
                <CheckBox x:Name="IgnoreGit"
                           Margin="16,0,0,0"
                           Content="跳过 .git 目录"
                           IsChecked="True" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Margin="16,8,16,0"
                Padding="0"
                ClipToBounds="True"
                Style="{StaticResource CardBorder}">
            <Grid>
                <ListView x:Name="ResultList"
                          Margin="0"
                          Padding="0"
                          Background="Transparent"
                          BorderThickness="0"
                          FontSize="13"
                          ItemContainerStyle="{StaticResource FluentListViewItem}"
                          SelectionMode="Single">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="80" Header="PID">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,2"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Background="{DynamicResource AccentFillColorDisabledBrush}"
                                                CornerRadius="{StaticResource ControlCornerRadius}">
                                            <TextBlock VerticalAlignment="Center"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                                       Text="{Binding ProcessId}" />
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="160" Header="进程名">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                            <Border Width="20"
                                                    Height="20"
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    Background="#1a10893e"
                                                    CornerRadius="{StaticResource ControlCornerRadius}">
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                           FontSize="11"
                                                           Foreground="#10893e"
                                                           Text="&#xE9D9;" />
                                            </Border>
                                            <TextBlock VerticalAlignment="Center"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding ProcessName}" />
                                            <Border Width="16"
                                                    Height="16"
                                                    Margin="4,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                    CornerRadius="8"
                                                    Cursor="Help"
                                                    ToolTip="{Binding ExePath}">
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                           FontSize="9"
                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                           Text="&#xE946;" />
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="150" Header="应用名">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock VerticalAlignment="Center"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Text="{Binding AppName}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="200" Header="占用文件">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock VerticalAlignment="Center"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                                   Text="{Binding LockedFile}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding LockedFile}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="80" Header="操作">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Click="KillProcess_Click"
                                                Content="结束"
                                                Style="{StaticResource DangerButton}"
                                                Tag="{Binding ProcessId}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <StackPanel x:Name="EmptyPanel"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Visible">
                    <TextBlock x:Name="EmptyIcon"
                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                               FontSize="40"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center"
                               Text="&#xE89F;" />
                    <TextBlock x:Name="EmptyText"
                               FontSize="14"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"
                               Text="拖拽文件或文件夹到此处，或输入路径后点击检测" />
                    <TextBlock x:Name="LoadingText"
                               FontSize="14"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Visibility="Collapsed"
                               Text="正在检测...">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="LoadingDotTransform" />
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBlock x:Name="LoadingSpinner"
                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                               FontSize="32"
                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                               HorizontalAlignment="Center"
                               Visibility="Collapsed"
                               Margin="0,0,0,8"
                               Text="&#xE712;">
                        <TextBlock.RenderTransform>
                            <RotateTransform x:Name="LoadingRotation" CenterX="16" CenterY="16" />
                        </TextBlock.RenderTransform>
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="LoadingRotation"
                                                         Storyboard.TargetProperty="Angle"
                                                         From="0" To="360" Duration="0:0:1.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock x:Name="BottomStatus"
                   Grid.Row="3"
                   Height="24"
                   Margin="16,6,16,8"
                   VerticalAlignment="Center"
                   FontSize="12"
                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                   Text="就绪" />
    </Grid>
</Window>
