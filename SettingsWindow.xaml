<Window x:Class="FileUnlocker.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Width="420"
        Height="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="CornerRadius" Value="{StaticResource OverlayCornerRadius}" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        </Style>
        <Style x:Key="SettingComboBox" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="MinWidth" Value="160" />
        </Style>
    </Window.Resources>

    <Grid Margin="20" RowDefinitions="Auto,Auto,*,Auto">
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
            <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0" x:Name="LangLabel" Text="" Style="{StaticResource SettingLabel}" />
                <ComboBox Grid.Column="1" x:Name="LangCombo" Style="{StaticResource SettingComboBox}" HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
            <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0" x:Name="ThemeLabel" Text="" Style="{StaticResource SettingLabel}" />
                <ComboBox Grid.Column="1" x:Name="ThemeCombo" Style="{StaticResource SettingComboBox}" HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button x:Name="CancelBtn" Content="" Padding="20,6" FontSize="13" MinWidth="80" Margin="0,0,8,0" Click="CancelBtn_Click" />
            <Button x:Name="SaveBtn" Content="" Style="{DynamicResource AccentButtonStyle}" Padding="20,6" FontSize="13" MinWidth="80" Click="SaveBtn_Click" />
        </StackPanel>
    </Grid>
</Window>
